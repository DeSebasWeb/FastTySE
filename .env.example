# ============================================================
# FastTyse — Variables de entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores.
#   cp .env.example .env
# ============================================================

# ---------- Base de datos local (PostgreSQL) ----------
# URL de conexion a la base de datos donde FastTyse almacena
# usuarios, asignaciones, evidencias y datos de los CSV.
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/fastyse

# ---------- Base de datos externa (solo lectura) ----------
# Conexion a la base de datos externa de donde se consultan
# datos del escrutinio. Puede ser la misma o una diferente.
EXTERNAL_DB_URL=postgresql://usuario:password@host:5432/nombre_db

# ---------- Auditor (API E14) ----------
# URL base de la app Auditor Escrutinio para obtener imagenes E14.
# Se usa para auto-adjuntar el E14 al crear evidencias.
AUDITOR_BASE_URL=https://tyseapps.com/auditorescrutinio

# ---------- Autenticacion ----------
# Secreto para firmar los JWT. Usa un valor largo y aleatorio en produccion.
JWT_SECRET=cambia-este-secreto-en-produccion

# ---------- Servidor ----------
# Puerto en el que corre el backend Express.
PORT=3001

# ---------- CORS / Cliente ----------
# URL(s) del frontend permitidas por CORS.
# En produccion con Docker, el cliente se sirve desde el mismo origen
# y esta variable se puede omitir.
# Para desarrollo local o multiples origenes, separar con coma:
#   CLIENT_URL=http://localhost:5173,http://192.168.1.100:5173
CLIENT_URL=http://localhost:5173

# ---------- Entorno ----------
# "production" en despliegues reales. Afecta CORS y optimizaciones.
NODE_ENV=production
